# Copy this file to .env and change the placeholder values before first deploy.

# PostgreSQL / Odoo credentials (must match between POSTGRES_PASSWORD and PASSWORD).
POSTGRES_PASSWORD=changeme
PASSWORD=changeme

# Bind the Nginx reverse proxy only to a specific LXC/Tailscale IP.
# Use the LXC 100 IP reachable from the Tailscale mesh; never 0.0.0.0 in production.
PROXY_BIND_IP=100.64.0.10
